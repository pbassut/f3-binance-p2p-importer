# Firefly-III Configuration
# Copy this file to .env and fill in your actual values

# Your Firefly-III API URL (without trailing slash)
FIREFLY_URL=https://your-firefly-instance.com

# Your Firefly-III API Token (Personal Access Token)
FIREFLY_TOKEN=your-firefly-api-token

# Your Firefly Data Importer Secret
FIREFLY_SECRET=your-firefly-data-importer-secret

# Email Monitoring Configuration (Optional)
# Set these to enable automatic processing of CSV attachments from emails
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_TLS=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_MAILBOX=INBOX
EMAIL_CHECK_INTERVAL=5

# Email Processor Mapping
# Maps sender email addresses to processor types and importer configs
# Format: JSON array of objects with senderEmail, processorType, and importerConfig
EMAIL_PROCESSORS='[
  {
    "senderEmail": "noreply@binance.com",
    "processorType": "binance",
    "importerConfig": "binance.json"
  },
  {
    "senderEmail": "alerts@itau.com.br",
    "processorType": "itau",
    "importerConfig": "itau.json"
  },
  {
    "senderEmail": "payments@deel.com",
    "processorType": "deel",
    "importerConfig": "deel.json"
  }
]'