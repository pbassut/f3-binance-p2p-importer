{
  "name": "f3-binance-p2p-importer",
  "version": "1.0.0",
  "description": "> **Universal CSV Converter for Binance P2P to Firefly-III**",
  "main": "src/main.ts",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "tsc",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "process:example": "ts-node scripts/process-example.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.1.2",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@types/imap": "^0.8.42",
    "axios": "^1.10.0",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "dotenv": "^17.0.1",
    "express": "^5.1.0",
    "i18next": "^23.10.1",
    "imap": "^0.8.19",
    "mailparser": "^3.7.4",
    "multer": "^2.0.1",
    "papaparse": "^5.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@types/express": "^4.17.23",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.0.7",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.10",
    "playwright": "^1.53.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
